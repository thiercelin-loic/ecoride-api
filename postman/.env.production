NODE_ENV=production
DB_HOST=your_production_db_host
DB_PORT=3306
DB_USERNAME=your_production_db_username
DB_PASSWORD=your_production_db_password
DB_DATABASE=your_production_db_name
DB_SSL=true
DB_SSL_CERT=path/to/production-cert.pem
DB_SSL_KEY=path/to/production-key.pem
DB_SSL_CA=path/to/production-ca.pem
